SELECT
    customer,
    category,
    revenue
FROM (
    SELECT
        customer,
        category,
        revenue,
        ROW_NUMBER() OVER (
            PARTITION BY customer
            ORDER BY revenue DESC
        ) AS rn
    FROM sales
) x
WHERE rn = 1;

