SELECT
    customer,
    category,
    revenue
FROM (
    SELECT
        customer,
        category,
        revenue,
        RANK() OVER (
            PARTITION BY customer
            ORDER BY revenue DESC
        ) AS rnk
    FROM sales
) x
WHERE rnk = 1;

SELECT
    customer,
    revenue,
    CASE
        WHEN revenue > 1000 THEN 'top'
        WHEN revenue > 500 THEN 'medium'
        ELSE 'low'
    END AS segment
FROM sales;

