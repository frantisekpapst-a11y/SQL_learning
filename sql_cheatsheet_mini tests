**Query #1**

    SELECT
    	c.customer_id,
        c.name,
        COALESCE(SUM(o.amount), 0) AS total_revenue,
        CASE
        	WHEN COALESCE(SUM(o.amount), 0) > 1000 THEN 'top'
            WHEN COALESCE(SUM(o.amount), 0) > 500 THEN 'medium'
            ELSE 'low'
     	END AS segment
    FROM customers c
    LEFT JOIN orders o
    	ON c.customer_id = o.customer_id
    GROUP BY
    	c.customer_id,
        c.name
    ORDER BY total_revenue DESC;

